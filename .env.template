# OpenClaw × Claude Code Integration — 环境变量配置模板
# 复制此文件为 ~/.openclaw/.env 并填入你的凭证
# DO NOT commit actual .env file to git，只保留 .env.template

# ─── Telegram Bot 凭证 ────────────────────────────────────────────────────
# 获取方式：@BotFather -> /newbot -> 获得 token
# Chat ID：在 Telegram 中转发消息到 @userinfobot 获取你的 chat ID
TG_BOT_TOKEN="your_telegram_bot_token_here"
TG_CHAT_ID="your_telegram_chat_id_here"

# ─── SiliconFlow API (embedding 服务) ──────────────────────────────────────
# 申请：https://cloud.siliconflow.cn
# 优先使用 SiliconFlow 的 BAAI/bge-m3 模型，因为速度快且免费额度充足
SILICONFLOW_API_KEY="sk_your_siliconflow_api_key_here"

# ─── MiniMax API (备选 embedding 和摘要生成) ────────────────────────────────
# 申请：https://api.minimaxi.com
# 仅在 SiliconFlow 不可用时作为 fallback 使用
MINIMAX_API_KEY="sk-your_minimax_api_key_here"

# ─── 其他可选配置 ────────────────────────────────────────────────────────────
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL="INFO"

# 是否启用自动 Telegram 通知
ENABLE_TELEGRAM_NOTIFICATIONS="true"

# memory-compaction 的定时任务（cron 格式）
MEMORY_COMPACTION_CRON="0 3 * * 0"  # 每周日 3:00 AM
